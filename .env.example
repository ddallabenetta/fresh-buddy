# LLM Server Configuration
LLM_PORT=8080
MODEL_NAME=model
MODEL_PATH=./models
CONTEXT_SIZE=4096
N_GPU_LAYERS=32

# LLM API (for fresh-buddy client)
LLM_API_KEY=not-needed
LLM_API_ENDPOINT=http://llm-server:8080/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TOP_P=0.9
# Optional: override the default assistant system prompt
# SYSTEM_PROMPT=Sei Fresh Buddy, un assistente AI amichevole...
# Optional: override the first spoken message at startup
FIRST_MESSAGE=Ciao! Sono Fresh Buddy. Come posso aiutarti?

# Piper TTS Voice
PIPER_VOICE=it_IT-paola-medium
TTS_VOLUME=0.3

# STT tuning
STT_MAIN_TIMEOUT=12.0
STT_FOLLOWUP_TIMEOUT=6.0
STT_STREAM_TIMEOUT=3.0
STT_ENERGY_THRESHOLD=500
STT_END_SILENCE_TIMEOUT=0.45
STT_FOLLOWUP_END_SILENCE_TIMEOUT=0.35
STT_STREAM_END_SILENCE_TIMEOUT=0.35
STT_PRE_ROLL_CHUNKS=3

# Fresh Buddy App
APP_PORT=5000
DEBUG_MODE=false
LOG_LEVEL=INFO
