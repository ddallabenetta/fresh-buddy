# LLM Server Configuration
LLM_PORT=8080
MODEL_NAME=model
MODEL_PATH=./models
CONTEXT_SIZE=4096
N_GPU_LAYERS=32

# LLM API (for fresh-buddy client)
LLM_API_KEY=not-needed
LLM_API_ENDPOINT=http://llm-server:8080/v1

# Piper TTS Voice
PIPER_VOICE=it_IT-riccardo-medium

# Fresh Buddy App
APP_PORT=5000
DEBUG_MODE=false
LOG_LEVEL=INFO
